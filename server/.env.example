# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
# Replace username, password, and cluster details with your own MongoDB Atlas URI or local MongoDB connection string
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app_name>"

# JWT Configuration
# Required for token signing and validation in authentication routes
JWT_SECRET=your_jwt_secret_key_here

# Google Gemini API
# Get your API key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Storage
# Required for file uploads/storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional: GitHub Personal Access Token (PAT) to prevent API rate-limiting in parser services
GITHUB_TOKEN=
