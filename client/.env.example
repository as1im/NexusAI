# NextAuth Configuration
# For production, set to your canonical domain (e.g. https://yourdomain.com)
# For local development, use http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret used to encrypt tokens and session state
# You can generate one using: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# GitHub OAuth App Credentials
# Create an OAuth Application in GitHub Settings > Developer Settings
# Authorization callback URL should be: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
